{
  "name": "@xlr8-nest/core",
  "version": "0.1.6",
  "description": "NestJS utility library with DDD, CQRS, TypeORM extensions, OpenAPI decorators, and Zod validation",
  "author": "",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./ddd": {
      "import": {
        "types": "./dist/ddd/index.d.mts",
        "default": "./dist/ddd/index.mjs"
      },
      "require": {
        "types": "./dist/ddd/index.d.ts",
        "default": "./dist/ddd/index.js"
      }
    },
    "./database": {
      "import": {
        "types": "./dist/database/index.d.mts",
        "default": "./dist/database/index.mjs"
      },
      "require": {
        "types": "./dist/database/index.d.ts",
        "default": "./dist/database/index.js"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/errors/index.d.mts",
        "default": "./dist/errors/index.mjs"
      },
      "require": {
        "types": "./dist/errors/index.d.ts",
        "default": "./dist/errors/index.js"
      }
    },
    "./openapi": {
      "import": {
        "types": "./dist/openapi/index.d.mts",
        "default": "./dist/openapi/index.mjs"
      },
      "require": {
        "types": "./dist/openapi/index.d.ts",
        "default": "./dist/openapi/index.js"
      }
    },
    "./response": {
      "import": {
        "types": "./dist/response/index.d.mts",
        "default": "./dist/response/index.mjs"
      },
      "require": {
        "types": "./dist/response/index.d.ts",
        "default": "./dist/response/index.js"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types/index.d.mts",
        "default": "./dist/types/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.js"
      }
    },
    "./validator": {
      "import": {
        "types": "./dist/validator/index.d.mts",
        "default": "./dist/validator/index.mjs"
      },
      "require": {
        "types": "./dist/validator/index.d.ts",
        "default": "./dist/validator/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^9.0.0 || ^10.0.0 || ^11.0.0 || ^12.0.0",
    "@nestjs/core": "^9.0.0 || ^10.0.0 || ^11.0.0 || ^12.0.0",
    "@nestjs/event-emitter": "^2.0.0 || ^3.0.0 || ^4.0.0",
    "@nestjs/swagger": "^6.0.0 || ^7.0.0 || ^8.0.0 || ^9.0.0 || ^10.0.0 || ^11.0.0",
    "@nestjs/typeorm": "^9.0.0 || ^10.0.0 || ^11.0.0 || ^12.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0 || ^0.3.0",
    "rxjs": "^7.0.0 || ^8.0.0",
    "typeorm": "^0.3.0 || ^0.4.0",
    "zod": "^3.0.0 || ^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/event-emitter": {
      "optional": true
    },
    "@nestjs/swagger": {
      "optional": true
    },
    "@nestjs/typeorm": {
      "optional": true
    },
    "typeorm": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@faker-js/faker": "^10.3.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@swc/core": "^1.15.30",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "nest-commander": "^3.0.0",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsup": "^8.0.0",
    "typeorm": "^0.3.28",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "zod": "^4.3.6"
  },
  "keywords": [
    "nestjs",
    "ddd",
    "cqrs",
    "typeorm",
    "openapi",
    "swagger",
    "zod",
    "validation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xlr8-nest/xlr8-nest-core"
  },
  "bugs": {
    "url": "https://github.com/xlr8-nest/xlr8-nest-core/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "engineStrict": false
}
